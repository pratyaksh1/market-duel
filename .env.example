# GEMINI_API_KEY: from aistudio.google.com (free)
GEMINI_API_KEY=your_gemini_key

# NEWS_API_KEY: from newsapi.org (free)
NEWS_API_KEY=your_news_key

# GMAIL_SENDER: your gmail address
GMAIL_SENDER=your_email@gmail.com

# GMAIL_APP_PASSWORD: from Google Account -> Security -> 2FA -> App Passwords
GMAIL_APP_PASSWORD=your_app_password

# RECIPIENT_EMAIL: where to send the podcast
RECIPIENT_EMAIL=recipient@example.com

# ELEVENLABS (Optional): leave blank for free Edge TTS
ELEVENLABS_API_KEY=
ELEVENLABS_HOST_A_VOICE_ID=
ELEVENLABS_HOST_B_VOICE_ID=
